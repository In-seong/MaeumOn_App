<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingTop="@dimen/margin_status_bar"
    android:background="@color/white"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".feature.splash.ui.PhoneCertFragment">

    <ImageView
        android:id="@+id/img_logo"
        android:layout_width="122dp"
        android:layout_height="wrap_content"
        android:src="@drawable/logo_mobiliteasy"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"/>

    <TextView
        android:id="@+id/txt_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="본인인증"
        android:textSize="20dp"
        android:fontFamily="@font/pretendard_semi_bold_font"
        android:textColor="@color/gray800"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/img_logo"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"/>

    <TextView
        android:id="@+id/txt_phone_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="휴대폰번호"
        android:textSize="16dp"
        android:textColor="@color/gray800"
        android:fontFamily="@font/pretendard_semi_bold_font"
        android:layout_marginTop="10dp"
        android:layout_marginStart="20dp"
        app:layout_constraintTop_toBottomOf="@id/txt_title"
        app:layout_constraintLeft_toLeftOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_phone"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:theme="@style/Theme.MaterialComponents.Light"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="8dp"
        app:cardElevation="1dp"
        android:layout_marginStart="20dp"
        app:layout_constraintEnd_toStartOf="@id/card_btn_send"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txt_phone_title"
        app:strokeColor="@color/gray300"
        app:strokeWidth="1dp">

        <EditText
            android:id="@+id/edit_phone"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/transparent"
            android:fontFamily="@font/pretendard_semi_bold_font"
            android:hint="ex) 010 0000 0000"
            android:maxLength="11"
            android:maxLines="1"
            android:inputType="phone"
            android:imeOptions="actionDone"
            android:paddingHorizontal="12dp"
            android:paddingVertical="14dp"
            android:singleLine="true"
            android:textColor="@color/gray800"
            android:textColorHint="@color/gray400"
            android:textSize="15dp" />
    </com.google.android.material.card.MaterialCardView>

    <androidx.cardview.widget.CardView
        android:id="@+id/card_btn_send"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        app:cardCornerRadius="8dp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="20dp"
        app:cardBackgroundColor="@color/color_primary"
        app:layout_constraintTop_toTopOf="@id/card_phone"
        app:layout_constraintBottom_toBottomOf="@id/card_phone"
        app:layout_constraintStart_toEndOf="@id/card_phone"
        app:layout_constraintEnd_toEndOf="parent">
        <Button
            android:id="@+id/btn_send"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/button_selector_view"
            android:text="전송"
            android:textSize="14dp"
            android:textColor="@color/white"
            android:fontFamily="@font/pretendard_semi_bold_font"/>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/txt_phone_err"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="invisible"
        android:text="*번호를 입력해 주세요."
        android:textSize="12dp"
        android:textColor="@color/color_warning"
        android:fontFamily="@font/pretendard_semi_bold_font"
        android:layout_marginTop="5dp"
        app:layout_constraintTop_toBottomOf="@id/card_phone"
        app:layout_constraintStart_toStartOf="@id/card_phone"/>

    <TextView
        android:id="@+id/txt_code_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="인증번호"
        android:textSize="16dp"
        android:textColor="@color/gray800"
        android:fontFamily="@font/pretendard_semi_bold_font"
        android:layout_marginTop="10dp"
        android:layout_marginStart="20dp"
        app:layout_constraintTop_toBottomOf="@id/txt_phone_err"
        app:layout_constraintLeft_toLeftOf="parent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_code"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:theme="@style/Theme.MaterialComponents.Light"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="8dp"
        app:cardElevation="1dp"
        android:layout_marginStart="20dp"
        app:layout_constraintEnd_toStartOf="@id/card_btn_ok"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txt_code_title"
        app:strokeColor="@color/gray300"
        app:strokeWidth="1dp">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <TextView
                android:id="@+id/txt_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textSize="15dp"
                android:textColor="@color/gray800"
                android:fontFamily="@font/pretendard_semi_bold_font"
                android:layout_marginEnd="16dp"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

            <EditText
                android:id="@+id/edit_code"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/transparent"
                android:fontFamily="@font/pretendard_semi_bold_font"
                android:hint="인증 번호를 입력해주세요."
                android:maxLength="5"
                android:maxLines="1"
                android:enabled="false"
                android:paddingHorizontal="12dp"
                android:paddingVertical="14dp"
                android:singleLine="true"
                android:textColor="@color/gray800"
                android:textColorHint="@color/gray400"
                android:textSize="15dp" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <androidx.cardview.widget.CardView
        android:id="@+id/card_btn_ok"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        app:cardCornerRadius="8dp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="20dp"
        app:cardBackgroundColor="@color/color_primary"
        app:layout_constraintTop_toTopOf="@id/card_code"
        app:layout_constraintBottom_toBottomOf="@id/card_code"
        app:layout_constraintStart_toEndOf="@id/card_code"
        app:layout_constraintEnd_toEndOf="parent">
        <Button
            android:id="@+id/btn_ok"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/button_selector_view"
            android:enabled="false"
            android:text="확인"
            android:textSize="14dp"
            android:textColor="@color/white"
            android:fontFamily="@font/pretendard_semi_bold_font"/>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/txt_code_err"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="invisible"
        android:text="*인증번호를 입력해 주세요."
        android:textSize="12dp"
        android:textColor="@color/color_warning"
        android:fontFamily="@font/pretendard_semi_bold_font"
        android:layout_marginTop="5dp"
        app:layout_constraintTop_toBottomOf="@id/card_code"
        app:layout_constraintStart_toStartOf="@id/card_code"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="본인인증은 하루 5회 제한됩니다."
        android:textSize="16dp"
        android:textColor="@color/gray800"
        android:fontFamily="@font/pretendard_semi_bold_font"
        android:layout_marginTop="30dp"
        app:layout_constraintTop_toBottomOf="@id/txt_code_err"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>