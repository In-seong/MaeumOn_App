<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:elevation="100dp"
    app:cardCornerRadius="20dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="@dimen/dialog_layout_padding">

        <TextView
            android:id="@+id/text_dialog_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="5dp"
            android:fontFamily="@font/pretendard_bold_font"
            android:gravity="center"
            android:textColor="@color/gray800"
            android:textSize="@dimen/dialog_title_text_size"
            app:layout_constraintBottom_toTopOf="@id/text_dialog_sub"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/text_dialog_sub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginVertical="10dp"
            android:fontFamily="@font/pretendard_semi_bold_font"
            android:gravity="center"
            android:textColor="@color/gray800"
            android:textSize="@dimen/dialog_message_text_size"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@id/text_dialog_title" />

        <androidx.cardview.widget.CardView
            android:id="@+id/card_dialog_yes"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:elevation="100dp"
            app:cardBackgroundColor="@color/color_primary"
            app:cardCornerRadius="8dp"
            app:cardUseCompatPadding="true"
            app:layout_constraintLeft_toRightOf="@id/card_dialog_no"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@id/text_dialog_sub">

            <Button
                android:id="@+id/button_dialog_yes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/button_selector_view"
                android:fontFamily="@font/pretendard_bold_font"
                android:text="@string/dialog_button_yes"
                android:textColor="@color/white"
                android:textSize="@dimen/dialog_button_text_size" />
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/card_dialog_no"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:elevation="100dp"
            app:cardBackgroundColor="@color/color_warning"
            app:cardCornerRadius="8dp"
            app:cardUseCompatPadding="true"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toLeftOf="@id/card_dialog_yes"
            app:layout_constraintTop_toTopOf="@id/card_dialog_yes">

            <Button
                android:id="@+id/button_dialog_no"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/button_selector_view"
                android:fontFamily="@font/pretendard_bold_font"
                android:text="@string/dialog_button_no"
                android:textColor="@color/white"
                android:textSize="@dimen/dialog_button_text_size" />
        </androidx.cardview.widget.CardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>